#!/usr/bin/env python3

import os
import sys

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
LIB_CANDIDATES = [
    os.path.join(SCRIPT_DIR, ".."),
    os.path.join(SCRIPT_DIR, "..", "lib", "ibus-arabizi"),
    "/usr/lib/ibus-arabizi",
    "/usr/local/lib/ibus-arabizi",
]

for candidate in LIB_CANDIDATES:
    resolved = os.path.abspath(candidate)
    if os.path.isdir(resolved) and resolved not in sys.path:
        sys.path.insert(0, resolved)

from arabizi_ibus.engine_main import main

if __name__ == "__main__":
    argv = sys.argv[1:] or ["--ibus"]
    raise SystemExit(main(argv))
